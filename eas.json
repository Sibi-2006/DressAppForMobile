{
    "cli": {
        "version": ">= 18.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "NPM_FLAGS": "--legacy-peer-deps"
            }
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "NPM_FLAGS": "--legacy-peer-deps"
            }
        },
        "production": {
            "distribution": "store",
            "android": {
                "buildType": "app-bundle"
            },
            "env": {
                "NPM_FLAGS": "--legacy-peer-deps"
            }
        },
        "release": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "NPM_FLAGS": "--legacy-peer-deps"
            }
        }
    },
    "submit": {
        "production": {
            "android": {
                "serviceAccountKeyPath": "./google-services.json",
                "track": "internal"
            }
        }
    }
}